# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
.env

# OS / editor
.DS_Store
.vscode/
.idea/

# Data - users provide their own BIDS root or BOLD files.
data/**
!data/.gitkeep

# Results - keep lightweight evaluation summaries, ignore generated volumes.
results/**
!results/.gitkeep
!results/**/
!results/**/*.csv
!results/**/*.json
!results/**/*.png
!results/**/*.txt
results/**/*.nii
results/**/*.nii.gz

# Checkpoints - keep metadata/history for reproducibility, ignore heavy tensors
# unless explicitly promoted to the shipped pretrained weights.
checkpoints/**
!checkpoints/.gitkeep
!checkpoints/**/
!checkpoints/**/README.md
!checkpoints/**/history.json
!checkpoints/**/config.yaml
!checkpoints/**/config.yml
!checkpoints/**/metrics.csv
!checkpoints/**/metrics.json
!checkpoints/pretrained/model_weights.pt
